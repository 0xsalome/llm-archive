---
import DefaultPageTitle from "@astrojs/starlight/components/PageTitle.astro";

const { entry } = Astro.locals.starlightRoute;
const data = entry.data;

const statusLabels = {
  seed: "🌱 seed",
  growing: "🌿 growing",
  checked: "🔎 checked",
  superseded: "🧭 superseded",
} as const;

const formatDate = (date: Date | string) => new Date(date).toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const splitTitle = (title: string) => {
  const match = title.match(/^(.*?)\s*(――|——)\s*(.+)$/);
  return match
    ? { main: match[1], separator: match[2], subtitle: match[3] }
    : { main: title, separator: "", subtitle: "" };
};
const titleParts = splitTitle(data.title);
---

{
  data.status && data.date ? (
    <div class="llm-note-heading">
      <div class="llm-note-meta">
        <span class={`llm-status llm-status-${data.status}`}>{statusLabels[data.status]}</span>
        <time datetime={formatDate(data.date)}>{formatDate(data.date)}</time>
      </div>

      <h1 id="_top" class:list={[titleParts.subtitle && "llm-split-title"]}>
        <span class="llm-title-main">{titleParts.main}</span>
        {
          titleParts.subtitle && (
            <span class="llm-title-sub">
              <span aria-hidden="true">{titleParts.separator}</span>
              {titleParts.subtitle}
            </span>
          )
        }
      </h1>
      {data.description && <p class="llm-note-description">{data.description}</p>}

      {
        data.tags.length > 0 && (
          <ul class="llm-tag-list" aria-label="Tags">
            {data.tags.map((tag) => (
              <li>
                <a href={`${base}/?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  ) : (
    <DefaultPageTitle />
  )
}
