---
import DefaultFooter from "@astrojs/starlight/components/Footer.astro";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

type AdditionType = "comment" | "related_case" | "correction" | "reference" | "memo";

type AdditionFrontmatter = {
  article?: string;
  title?: string;
  displayName?: string;
  type?: AdditionType | string;
  createdAt?: Date | string;
};

type AdditionModule = {
  frontmatter?: AdditionFrontmatter;
  Content?: AstroComponentFactory;
};

const { starlightRoute } = Astro.locals;
const entryId = starlightRoute.entry.id;
const articleSlug = entryId.split("/").filter(Boolean).at(-1) ?? entryId;
const isArchiveArticle = entryId.startsWith("archive/") && Boolean(articleSlug);

const githubOwner = import.meta.env.PUBLIC_GITHUB_OWNER || "0xsalome";
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO || "llm-archive";

const articleTitle = starlightRoute.entry.data.title ?? articleSlug;

const issueTemplate = `<!-- article: ${articleSlug} -->

記事「${articleTitle}」への追記案・コメント・関連事例・補足・反証メモなどをここに書いてください。
`;

const githubIssueUrl = new URL(`https://github.com/${githubOwner}/${githubRepo}/issues/new`);
githubIssueUrl.searchParams.set("title", `コメント: ${articleTitle}`);
githubIssueUrl.searchParams.set("body", issueTemplate);
githubIssueUrl.searchParams.set("labels", "comment");

const noteModules = import.meta.glob<AdditionModule>("../../../content/notes/**/*.md", { eager: true });

const formatDate = (value: unknown) => {
  if (!value) return "";
  if (value instanceof Date) return value.toISOString().slice(0, 10);
  const date = new Date(String(value));
  return Number.isNaN(date.valueOf()) ? String(value) : date.toISOString().slice(0, 10);
};

const additions = Object.entries(noteModules)
  .map(([path, module]) => {
    const match = path.replace(/\\/g, "/").match(/\/content\/notes\/([^/]+)\/([^/]+\.md)$/);
    const frontmatter = module.frontmatter ?? {};

    return {
      path,
      directorySlug: match?.[1] ?? "",
      fileName: match?.[2] ?? "",
      frontmatter,
      Content: module.Content,
    };
  })
  .filter((note) => {
    const article = note.frontmatter.article;
    return note.directorySlug === articleSlug && article === articleSlug && note.Content;
  })
  .sort((a, b) => {
    const aDate = formatDate(a.frontmatter.createdAt);
    const bDate = formatDate(b.frontmatter.createdAt);
    return aDate.localeCompare(bDate) || a.fileName.localeCompare(b.fileName);
  });
---

{
  isArchiveArticle && (
    <div
      class="llm-additions"
      data-llm-comments
      data-owner={githubOwner}
      data-repo={githubRepo}
      data-slug={articleSlug}
    >
      {
        additions.length > 0 && (
          <section class="llm-additions-list" aria-labelledby="llm-additions-heading">
            <h2 id="llm-additions-heading">追記・コメント</h2>
            <div class="llm-addition-cards">
              {additions.map((note) => {
                const Content = note.Content;
                const title = note.frontmatter.title || "追記案";
                const displayName = note.frontmatter.displayName || "";
                const createdAt = formatDate(note.frontmatter.createdAt);

                return (
                  <article class="llm-addition-card">
                    <header class="llm-addition-card-header">
                      <h3>{title}</h3>
                      <div class="llm-addition-meta">
                        {displayName && <span>{displayName}</span>}
                        {createdAt && <time datetime={createdAt}>{createdAt}</time>}
                      </div>
                    </header>
                    <div class="llm-addition-body">{Content && <Content />}</div>
                  </article>
                );
              })}
            </div>
          </section>
        )
      }

      <section class="llm-additions-list llm-issue-comments" aria-labelledby="llm-comments-heading" hidden>
        <h2 id="llm-comments-heading">コメント</h2>
        <div class="llm-addition-cards" data-comment-cards />
      </section>

      <aside class="llm-addition-cta" aria-label="追記案やコメント">
        <p>
          このページへの追記案や関連メモを送れます。GitHubアカウントがあれば、その場でコメントを追加できます。
        </p>
        <a class="llm-addition-button" href={githubIssueUrl.toString()} target="_blank" rel="noreferrer">
          <svg class="llm-addition-button-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              fill-rule="evenodd"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            />
          </svg>
          <span>GitHubでコメントを追加</span>
        </a>
      </aside>
    </div>
  )
}

<DefaultFooter />

<script>
  async function loadLlmComments() {
    const container = document.querySelector<HTMLElement>("[data-llm-comments]");
    if (!container) return;

    const owner = container.dataset.owner;
    const repo = container.dataset.repo;
    const slug = container.dataset.slug;
    const section = container.querySelector<HTMLElement>(".llm-issue-comments");
    const list = container.querySelector<HTMLElement>("[data-comment-cards]");
    if (!owner || !repo || !slug || !section || !list || list.childElementCount > 0) return;

    const marker = `<!-- article: ${slug} -->`;
    const endpoint = `https://api.github.com/repos/${owner}/${repo}/issues?labels=comment&state=open&per_page=100&sort=created&direction=asc`;

    let issues: any;
    try {
      const res = await fetch(endpoint, { headers: { Accept: "application/vnd.github+json" } });
      if (!res.ok) return;
      issues = await res.json();
    } catch {
      return;
    }
    if (!Array.isArray(issues)) return;

    const dateFmt = new Intl.DateTimeFormat("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" });

    const cards = issues
      .filter((issue) => !issue.pull_request && typeof issue.body === "string" && issue.body.includes(marker))
      .map((issue) => {
        const body = issue.body.replace(marker, "").trim();

        const card = document.createElement("article");
        card.className = "llm-addition-card";

        const header = document.createElement("header");
        header.className = "llm-addition-card-header";

        const meta = document.createElement("div");
        meta.className = "llm-addition-meta";

        if (issue.user?.login) {
          const author = document.createElement("a");
          author.href = issue.user.html_url;
          author.target = "_blank";
          author.rel = "noreferrer";
          author.textContent = issue.user.login;
          meta.appendChild(author);
        }

        const created = issue.created_at ? new Date(issue.created_at) : null;
        if (created && !Number.isNaN(created.valueOf())) {
          const time = document.createElement("time");
          time.dateTime = issue.created_at;
          time.textContent = dateFmt.format(created);
          meta.appendChild(time);
        }

        const link = document.createElement("a");
        link.href = issue.html_url;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.textContent = "GitHubで見る";
        meta.appendChild(link);

        header.appendChild(meta);
        card.appendChild(header);

        const bodyEl = document.createElement("div");
        bodyEl.className = "llm-addition-body llm-comment-body";
        bodyEl.textContent = body;
        card.appendChild(bodyEl);

        return card;
      });

    if (cards.length === 0) return;

    for (const card of cards) list.appendChild(card);
    section.hidden = false;
  }

  loadLlmComments();
  document.addEventListener("astro:page-load", loadLlmComments);
</script>

<style>
  .llm-additions {
    margin-top: 3rem;
    display: grid;
    gap: 1.25rem;
  }

  .llm-additions-list {
    display: grid;
    gap: 1rem;
  }

  .llm-additions-list h2 {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 1rem;
    font-weight: 850;
    letter-spacing: 0;
  }

  .llm-addition-cards {
    display: grid;
    gap: 0.85rem;
  }

  .llm-addition-card {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 6px;
    padding: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg) 82%, var(--sl-color-gray-6));
  }

  .llm-addition-card-header {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.7rem;
  }

  .llm-addition-card h3 {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 0.95rem;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .llm-addition-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    color: var(--sl-color-gray-3);
    font-size: 0.74rem;
  }

  .llm-addition-meta a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
  }

  .llm-addition-meta a:hover {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }

  .llm-comment-body {
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .llm-addition-body {
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .llm-addition-body :global(*:first-child) {
    margin-top: 0;
  }

  .llm-addition-body :global(*:last-child) {
    margin-bottom: 0;
  }

  .llm-addition-cta {
    display: grid;
    gap: 0.8rem;
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.25rem;
  }

  .llm-addition-cta p {
    margin: 0;
    max-width: 42rem;
    color: var(--sl-color-gray-3);
    font-size: 0.86rem;
    line-height: 1.7;
  }

  .llm-addition-button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    border: 1px solid var(--sl-color-accent);
    border-radius: 4px;
    padding: 0.55rem 0.75rem;
    background: transparent;
    color: var(--sl-color-accent-high);
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1.2;
    text-decoration: none;
  }

  .llm-addition-button-icon {
    flex-shrink: 0;
  }

  .llm-addition-button:hover {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-white);
  }
</style>
