---
import { getCollection } from "astro:content";
import "../index.css";

const entries = (await getCollection("docs")).filter((entry) => entry.id !== "404");
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statuses = ["seed", "growing", "checked", "superseded"] as const;
const statusLabels = {
  seed: "🌱 seed",
  growing: "🌿 growing",
  checked: "🔎 checked",
  superseded: "🧭 superseded",
} as const;
const counts = Object.fromEntries(statuses.map((status) => [status, 0])) as Record<(typeof statuses)[number], number>;
const tagCounts = new Map<string, number>();

for (const entry of entries) {
  counts[entry.data.status] += 1;
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entryById = new Map(entries.map((entry) => [entry.id, entry]));
const categories = [
  {
    label: "Start Here",
    items: ["archive/first-note"],
  },
  {
    label: "Technology",
    items: ["archive/sound-body-brain-waves", "archive/everyday-uncanny-technologies-japan"],
  },
  {
    label: "Ecology",
    items: ["archive/environmental-humanities-minakata-suiten"],
  },
  {
    label: "References",
    items: ["archive/github-open-source-license-lineage"],
  },
]
  .map((category) => ({
    ...category,
    entries: category.items
      .map((id) => entryById.get(id))
      .filter(Boolean)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
  }))
  .filter((category) => category.entries.length > 0);
const sortedTags = Array.from(tagCounts.entries()).sort(([tagA, countA], [tagB, countB]) => {
  if (countA !== countB) return countB - countA;
  return tagA.localeCompare(tagB, "ja");
});

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const splitTitle = (title: string) => {
  const match = title.match(/^(.*?)\s*(――|——)\s*(.+)$/);
  return match
    ? { main: match[1], subtitle: match[3] }
    : { main: title, subtitle: "" };
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LLM書庫</title>
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <meta
      name="description"
      content="未完成の問い、観察、仮説、読書メモ、AIとの対話から生まれた知識片を置くための小さな書庫。"
    />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("starlight-theme");
        document.documentElement.dataset.theme = storedTheme === "dark" ? "dark" : "light";
      })();
    </script>
  </head>
  <body class="home-page">
    <div class="vault-shell">
      <aside class="vault-sidebar">
        <section>
          <p class="small-label">Archive Status</p>
          <nav class="status-list" aria-label="Status overview">
            {
              statuses.map((status) => (
                <a class={`status-row status-${status}`} href={`#${status}`}>
                  <span class="status-name">
                    <span class="status-dot" />
                    {statusLabels[status]}
                  </span>
                  <span class="status-count">{counts[status]}</span>
                </a>
              ))
            }
          </nav>
        </section>

        <section>
          <p class="small-label">Tags</p>
          <div class="tag-cloud" data-tag-cloud>
            <a class="tag is-active" href={`${base}/`} data-tag-filter="" aria-current="true">
              All
              <span class="tag-count">{entries.length}</span>
            </a>
            {
              sortedTags.map(([tag, count]) => (
                <a class="tag" href={`${base}/?tag=${encodeURIComponent(tag)}`} data-tag-filter={tag}>
                  #{tag}
                  <span class="tag-count">{count}</span>
                </a>
              ))
            }
          </div>
        </section>
      </aside>

      <main class="vault-main">
        <header>
          <div class="home-heading-row">
            <p class="small-label">LLM Archive</p>
            <div class="home-actions">
              <a class="home-link-button" href="https://0xsalome.github.io/at-an-arbor/">HOME∴</a>
              <button class="theme-toggle" type="button" aria-label="テーマを切り替える" data-theme-toggle>
                <svg class="theme-icon theme-icon-light" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1Zm.64 5-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17ZM12 5a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1Zm5.66 2.34a1 1 0 0 0 .7-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.66.71a1 1 0 0 0 0 1.41 1 1 0 0 0 .66.29Zm-12-.29a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.71-.71a1.004 1.004 0 1 0-1.43 1.41l.73.71ZM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2Zm-2.64 6A1 1 0 0 0 17 18.36l.71.71a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.76-.66ZM12 6.5a5.5 5.5 0 1 0 5.5 5.5A5.51 5.51 0 0 0 12 6.5Zm0 9a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0 3.5a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1Z" />
                </svg>
                <svg class="theme-icon theme-icon-dark" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M21.64 13a1 1 0 0 0-1.05-.14 8.049 8.049 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05Zm-9.5 6.69A8.14 8.14 0 0 1 7.08 5.22v.27a10.15 10.15 0 0 0 10.14 10.14 9.784 9.784 0 0 0 2.1-.22 8.11 8.11 0 0 1-7.18 4.32v-.04Z" />
                </svg>
              </button>
            </div>
          </div>
          <h1 class="site-title">LLM書庫</h1>
          <p class="site-description">
            未完成の問い、観察、仮説、読書メモ、AIとの対話から生まれた知識片を置くための小さな書庫。
          </p>
          <p class="filter-state" data-filter-state>All</p>
        </header>

        <section class="card-grid" aria-label="Archive entries">
          {
            entries.map((entry) => {
              const titleParts = splitTitle(entry.data.title);

              return (
                <a class="paper-card" id={entry.data.status} href={`${base}/${entry.id}/`} data-entry-card data-tags={entry.data.tags.join("|")}>
                  <div>
                    <div class="card-top">
                      <span class={`status-stamp status-${entry.data.status}`}>{statusLabels[entry.data.status]}</span>
                      <time class="card-date" datetime={formatDate(entry.data.date)}>
                        {formatDate(entry.data.date)}
                      </time>
                    </div>
                    <h2 class:list={["card-title", titleParts.subtitle && "card-title-split"]}>
                      <span class="card-title-main">{titleParts.main}</span>
                      {
                        titleParts.subtitle && (
                          <span class="card-title-sub">
                            <span aria-hidden="true">——</span>
                            {titleParts.subtitle}
                          </span>
                        )
                      }
                    </h2>
                    <p class="card-description">{entry.data.description}</p>
                  </div>
                  <div class="card-tags">
                    {entry.data.tags.map((tag) => <span class="card-tag">#{tag}</span>)}
                  </div>
                </a>
              );
            })
          }
          <p class="empty-state" data-empty-state hidden>該当する記事はまだありません。</p>
        </section>
      </main>

      <aside class="vault-preview">
        <div>
          <p class="small-label">Categories</p>
        </div>

        {
          categories.length > 0 ? (
            <nav class="home-category-list" aria-label="Archive categories">
              {categories.map((category) => (
                <section class="home-category-group">
                  <div class="home-category-heading">
                    <h2>{category.label}</h2>
                    <span>{category.entries.length}</span>
                  </div>
                  <ul>
                    {category.entries.slice(0, 3).map((entry) => (
                      <li>
                        <a href={`${base}/${entry.id}/`}>
                          <span>{entry.data.title}</span>
                          <span class={`status-stamp status-${entry.data.status}`}>
                            {statusLabels[entry.data.status]}
                          </span>
                        </a>
                      </li>
                    ))}
                    {category.entries.slice(3).map((entry) => (
                      <li hidden data-category-extra>
                        <a href={`${base}/${entry.id}/`}>
                          <span>{entry.data.title}</span>
                          <span class={`status-stamp status-${entry.data.status}`}>
                            {statusLabels[entry.data.status]}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  {category.entries.length > 3 && (
                    <button
                      class="category-tab-toggle"
                      type="button"
                      aria-expanded="false"
                      data-category-toggle
                    >
                      All
                    </button>
                  )}
                </section>
              ))}
            </nav>
          ) : (
            <p class="preview-description">まだ記事がありません。</p>
          )
        }
      </aside>
    </div>

    <footer class="site-footer">
      <p>
        Design philosophy and site structure adapted from
        <a href="https://kotowari-modoki.github.io/experimental-commons/">experimental-commons</a>.
      </p>
      <p>
        Maintained by
        <a href="https://github.com/0xsalome">@0xsalome</a>.
      </p>
    </footer>

    <script>
      const applyTheme = (theme) => {
        const nextTheme = theme === "dark" ? "dark" : "light";
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem("starlight-theme", nextTheme);
      };

      applyTheme(localStorage.getItem("starlight-theme"));

      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        applyTheme(document.documentElement.dataset.theme === "dark" ? "light" : "dark");
      });

      const cards = Array.from(document.querySelectorAll("[data-entry-card]"));
      const tagButtons = Array.from(document.querySelectorAll("[data-tag-filter]"));
      const filterState = document.querySelector("[data-filter-state]");
      const emptyState = document.querySelector("[data-empty-state]");

      const setActiveTag = (tag, shouldUpdateUrl = true) => {
        let matchCount = 0;

        cards.forEach((card) => {
          const tags = (card.dataset.tags || "").split("|").filter(Boolean);
          const isMatch = !tag || tags.includes(tag);
          card.hidden = false;
          card.classList.toggle("is-dimmed", Boolean(tag) && !isMatch);
          card.style.order = tag ? (isMatch ? "0" : "1") : "";
          if (isMatch) matchCount += 1;
        });

        tagButtons.forEach((button) => {
          const isActive = (button.dataset.tagFilter || "") === tag;
          button.classList.toggle("is-active", isActive);
          if (isActive) {
            button.setAttribute("aria-current", "true");
          } else {
            button.removeAttribute("aria-current");
          }
        });

        if (filterState) {
          filterState.textContent = tag ? `#${tag} · ${matchCount}/${cards.length}` : "All";
        }
        if (emptyState) emptyState.hidden = !tag || matchCount > 0;

        if (shouldUpdateUrl) {
          const url = new URL(window.location.href);
          if (tag) {
            url.searchParams.set("tag", tag);
          } else {
            url.searchParams.delete("tag");
          }
          window.history.replaceState({}, "", url);
        }
      };

      tagButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          event.preventDefault();
          setActiveTag(button.dataset.tagFilter || "");
        });
      });

      setActiveTag(new URLSearchParams(window.location.search).get("tag") || "", false);

      document.querySelectorAll("[data-category-toggle]").forEach((button) => {
        button.addEventListener("click", () => {
          const group = button.closest(".home-category-group");
          const extras = Array.from(group?.querySelectorAll("[data-category-extra]") || []);
          const isExpanded = button.getAttribute("aria-expanded") === "true";

          extras.forEach((item) => {
            item.hidden = isExpanded;
          });

          button.setAttribute("aria-expanded", String(!isExpanded));
          button.textContent = isExpanded ? "All" : "Latest 3";
        });
      });
    </script>
  </body>
</html>
